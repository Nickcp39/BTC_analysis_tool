from pathlib import Path
import pandas as pd, numpy as np
import matplotlib.pyplot as plt

# ===== 配置 =====
F_21 = Path("btc_2021.xlsx")
F_25 = Path("btc_2025.xlsx")
OUTDIR = Path("btc_fit_outputs")
OUTDIR.mkdir(exist_ok=True)

PRE_DAYS, POST_DAYS = 120, 120
ANCHOR_2025 = pd.Timestamp("2025-08-15")
END_2025    = pd.Timestamp("2025-08-22")

# ===== 工具函数 =====
def read_two_col_excel(fp: Path) -> pd.DataFrame:
    assert fp.exists(), f"未找到文件：{fp}"
    df_raw = pd.read_excel(fp, engine="openpyxl", header=None)
    # 若是“横着两行”（第一行时间，第二行价格），自动转置
    if df_raw.shape[0] <= 3 and df_raw.shape[1] > df_raw.shape[0]:
        df_raw = df_raw.T
    df = df_raw.iloc[:, :2].copy()
    df.columns = ["ts", "price"]
    df["ts"] = pd.to_datetime(df["ts"], errors="coerce")
    df["price"] = pd.to_numeric(df["price"], errors="coerce")
    df = df.dropna(subset=["ts", "price"]).sort_values("ts").drop_duplicates(subset=["ts"], keep="last")
    return df

def to_daily_series(df: pd.DataFrame, start=None, end=None) -> pd.Series:
    if start is None: start = df["ts"].min().normalize()
    if end   is None: end   = df["ts"].max().normalize()
    s = df.set_index("ts")["price"].resample("D").last()
    s = s.reindex(pd.date_range(start, end, freq="D")).ffill()
    s.index.name = "ts"
    return s

def make_rel_curve(daily: pd.Series, anchor_date: pd.Timestamp, pre_days: int, post_days: int):
    anchor_date = pd.Timestamp(anchor_date).normalize()
    lo = max(anchor_date - pd.Timedelta(days=pre_days), daily.index.min())
    hi = min(anchor_date + pd.Timedelta(days=post_days), daily.index.max())
    win = daily.loc[lo:hi].copy()
    # 锚点价（若当日无值，取锚点日前最近可得值）
    anchor_px = float(win.loc[anchor_date] if anchor_date in win.index else win.loc[:anchor_date].iloc[-1])
    rel_day  = (win.index - anchor_date).days
    norm     = win / anchor_px                   # 锚点=1
    dd_pct   = (norm - 1.0) * 100.0              # 锚点=0%
    out = pd.DataFrame({"rel_day": rel_day, "norm": norm.values, "dd_pct": dd_pct.values}, index=win.index)
    return out, anchor_px

def corr_rmse(a: pd.Series, b: pd.Series):
    idx = a.index.intersection(b.index)
    if len(idx) < 3: 
        return np.nan, np.nan
    aa, bb = a.loc[idx].values, b.loc[idx].values
    r = np.corrcoef(aa, bb)[0,1]
    rmse = float(np.sqrt(np.mean((aa - bb)**2)))
    return float(r), rmse

# ===== 读取与预处理 =====
df21 = read_two_col_excel(F_21)
df25 = read_two_col_excel(F_25)

d21_full = to_daily_series(df21)
d25_full = to_daily_series(df25)

d21 = d21_full.loc["2021-01-01":"2021-12-31"]
d25 = d25_full.loc["2025-01-01":END_2025]

assert not d21.empty, "2021 年数据为空，请检查 btc_2021.xlsx"
assert not d25.empty, "2025 年数据为空，请检查 btc_2025.xlsx"

# 2021 锚点 = 2021 年内最高价当天（如需固定 11/10 可改行）
peak_2021_date = d21.idxmax()

rel21, anchor21 = make_rel_curve(d21, peak_2021_date, PRE_DAYS, POST_DAYS)
rel25, anchor25 = make_rel_curve(d25, ANCHOR_2025, PRE_DAYS, POST_DAYS)

# ===== 百分比“形状”比较（锚点前/后）=====
pre21 = rel21.loc[rel21["rel_day"]<=0].set_index("rel_day")["dd_pct"]
pre25 = rel25.loc[rel25["rel_day"]<=0].set_index("rel_day")["dd_pct"]
post21 = rel21.loc[rel21["rel_day"]>=0].set_index("rel_day")["dd_pct"]
post25 = rel25.loc[rel25["rel_day"]>=0].set_index("rel_day")["dd_pct"]

r_pre,  rmse_pre  = corr_rmse(pre21,  pre25)
r_post, rmse_post = corr_rmse(post21, post25)

# ===== 额外：波动缩放（把 2025 的百分比曲线按 2021 的标准差缩放）=====
# 仅用“锚点前 90 天”的波动估计（可按需调整）
span = range(-90, 1)
std21 = pre21.loc[list(filter(lambda x: x in pre21.index, span))].std(ddof=0)
std25 = pre25.loc[list(filter(lambda x: x in pre25.index, span))].std(ddof=0)
scale = (std21 / std25) if (std21==std21 and std25>0) else 1.0  # 防 NaN
pre25_s  = pre25 * scale
post25_s = post25 * scale
r_pre_s,  rmse_pre_s  = corr_rmse(pre21,  pre25_s)
r_post_s, rmse_post_s = corr_rmse(post21, post25_s)

# ===== 保存合并数据 & 指标 =====
merged = (rel21[["rel_day","dd_pct"]].rename(columns={"dd_pct":"dd_pct_2021"})
          .join(rel25[["rel_day","dd_pct"]].rename(columns={"dd_pct":"dd_pct_2025"}), how="outer"))
merged["dd_pct_2025_scaled"] = merged["dd_pct_2025"] * scale
merged.to_csv(OUTDIR / "merged_ddpct_anchor_window.csv", encoding="utf-8-sig", index_label="ts")

with open(OUTDIR / "fit_metrics.txt","w", encoding="utf-8") as f:
    f.write(f"2021 锚点：{peak_2021_date.date()}，锚点价={anchor21:,.2f}\n")
    f.write(f"2025 锚点：{ANCHOR_2025.date()}（假设），锚点价={anchor25:,.2f}\n\n")
    f.write("—— 未缩放（百分比）——\n")
    f.write(f"锚点前 r={r_pre:.4f}, RMSE={rmse_pre:.3f} pct-pt\n")
    f.write(f"锚点后 r={r_post:.4f}, RMSE={rmse_post:.3f} pct-pt\n\n")
    f.write("—— 波动缩放（已把2025按2021的std缩放）——\n")
    f.write(f"缩放系数 scale={scale:.3f}（>1 表示 25 年波动被放大）\n")
    f.write(f"锚点前 r={r_pre_s:.4f}, RMSE={rmse_pre_s:.3f} pct-pt\n")
    f.write(f"锚点后 r={r_post_s:.4f}, RMSE={rmse_post_s:.3f} pct-pt\n")

# ===== 画图（保存到文件夹）=====
# 图1：锚点归一化（百分比；未缩放）
plt.figure(figsize=(10,4))
plt.plot(rel21["rel_day"], rel21["dd_pct"], label=f"2021（锚点 {peak_2021_date.date()}）")
plt.plot(rel25["rel_day"], rel25["dd_pct"], label=f"2025（锚点 {ANCHOR_2025.date()}）")
plt.axvline(0, linestyle="--")
plt.xlabel("相对天数（锚点=0）"); plt.ylabel("相对锚点涨跌（%）")
plt.title("锚点归一化百分比（未缩放）"); plt.legend(); plt.tight_layout()
plt.savefig(OUTDIR / "pct_norm_unscaled.png", dpi=160); plt.close()

# 图2：锚点后回撤轨迹（未缩放）
plt.figure(figsize=(10,4))
plt.plot(post21.index, post21.values, label="2021：锚点后（%）")
plt.plot(post25.index, post25.values, label="2025：锚点后（%）")
plt.axvline(0, linestyle="--")
plt.xlabel("相对天数（锚点=0）"); plt.ylabel("相对锚点涨跌（%）")
plt.title("锚点后回撤轨迹对比（未缩放）"); plt.legend(); plt.tight_layout()
plt.savefig(OUTDIR / "post_peak_drawdown_unscaled.png", dpi=160); plt.close()

# 图3：锚点后回撤轨迹（对 2025 做波动缩放）
plt.figure(figsize=(10,4))
plt.plot(post21.index, post21.values, label="2021：锚点后（%）")
plt.plot(post25_s.index, post25_s.values, label=f"2025（已缩放 ×{scale:.2f}）")
plt.axvline(0, linestyle="--")
plt.xlabel("相对天数（锚点=0）"); plt.ylabel("相对锚点涨跌（%）")
plt.title("锚点后回撤轨迹对比（波动缩放后）"); plt.legend(); plt.tight_layout()
plt.savefig(OUTDIR / "post_peak_drawdown_scaled.png", dpi=160); plt.close()

print("已输出到：", OUTDIR.resolve())
